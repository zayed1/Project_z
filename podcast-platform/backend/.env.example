# ============================================
# إعدادات الخادم | Server Configuration
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# إعدادات Supabase | Supabase Configuration
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ============================================
# إعدادات JWT | JWT Configuration
# ============================================
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRES_IN=7d

# ============================================
# إعدادات Supabase Storage | Storage Config
# ============================================
SUPABASE_STORAGE_BUCKET=podcast-audio

# ============================================
# إعدادات CORS | CORS Configuration
# ============================================
FRONTEND_URL=http://localhost:5173
